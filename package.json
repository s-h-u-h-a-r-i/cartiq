{
  "name": "cartiq",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:mock": "vite --mode mock --port 3001",
    "typeCheck": "bun tsc --noEmit",
    "build": "vite build",
    "serve": "vite preview",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:restart": "supabase stop && supabase start",
    "db:reset": "supabase db reset",
    "db: migration": "supabase migration new",
    "db:types:local": "supabase gen types typescript --local > src/supabase/database.types.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/supabase/database.types.ts",
    "db:reset:types:local": "supabase db reset && bun run db:types:local",
    "db:push": "supabase db push"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "sass": "^1.101.0",
    "solid-devtools": "^0.34.3",
    "typescript": "^5.7.2",
    "vite": "^7.1.4",
    "vite-plugin-solid": "^2.11.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "effect": "^3.21.3",
    "lucide-solid": "^1.20.0",
    "solid-js": "^1.9.5"
  }
}
