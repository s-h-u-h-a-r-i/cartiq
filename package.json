{
  "name": "cartiq",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:preview": "vite --config preview/vite.config.ts",
    "build": "tsc -b && vite build",
    "build:preview": "tsc -p preview/tsconfig.json && vite build --config preview/vite.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:restart": "supabase stop && supabase start",
    "db:reset": "supabase db reset",
    "db:migration": "supabase migration new",
    "db:types:local": "supabase gen types typescript --local > src/lib/supabase/database.types.ts",
    "db:types:remote": "supabase gen types typescript --linked > src/lib/supabase/database.types.ts",
    "db:reset:types:local": "supabase db reset && bun run db:types:local",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "effect": "^3.21.2",
    "lucide-solid": "^1.16.0",
    "sass": "^1.99.0",
    "solid-devtools": "^0.34.5",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "supabase": "^2.101.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-solid": "^2.11.12"
  }
}
